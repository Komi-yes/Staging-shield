</section>

<div class="footer">
  Generado por Staging Shield · {{.GeneratedAt}} · Modelo de Evaluación de Seguridad para Entornos de Preproducción
</div>

<div id="toast" class="toast" role="status" aria-live="polite"></div>

</div>
<script>
(function() {
  "use strict";

  // ====================================================================
  // Datos canónicos del entorno (para exportar el archivo de revisión)
  // ====================================================================
  const ENV_META = {
    name:      "{{.Env.EnvironmentName}}",
    type:      "{{.Env.EnvironmentType}}",
    stack:     "{{.Env.StackType}}",
    target:    "{{.Env.Target}}",
    timestamp: "{{.GeneratedAt}}"
  };
  const DOMAIN_WEIGHTS = {
    {{range .DomainList}}"{{.Name}}": 1.0,
    {{end}}
  };

  // ====================================================================
  // Recálculo del Security Score, cobertura y aptitud en tiempo real.
  //
  // El cálculo replica la fórmula del modelo:
  //
  //   Score = 100 * Σ(c · w · d) / Σ(w · d)
  //
  // donde c ∈ {0, 0.5, 1.0}, w = severidad y d = peso del dominio.
  // El JS solo recorre el DOM una vez y agrega por dominio. Es O(n) sobre
  // las 36 SVR; para este tamaño no necesitamos índices ni cachés.
  // ====================================================================
  const verdicts = {}; // ruleId -> { status, evidence }

  function getRuleEffectiveStatus(ruleEl) {
    const id = ruleEl.dataset.ruleId;
    if (verdicts[id]) return verdicts[id].status; // veredicto humano
    return ruleEl.dataset.initialStatus;          // estado del motor
  }

  function statusToNumeric(s) {
    switch (s) {
      case "cumple":   return 1.0;
      case "parcial":  return 0.5;
      case "nocumple": return 0.0;
      default:         return null; // pendiente / falta-evidencia / manual / naplica → no entra al cálculo
    }
  }

  function scoreClass(s) {
    if (s >= 80) return "score-good";
    if (s >= 60) return "score-warn";
    return "score-bad";
  }

  // Algunos rule cards aparecen duplicados (CriticalView reaparece en
  // FailedView, una regla cumplida puede aparecer en PassedView, etc.).
  // Para no contar dos veces deduplicamos por ID antes de agregar.
  function uniqueRules() {
    const seen = new Set();
    const out = [];
    document.querySelectorAll('[data-rule-id]').forEach(el => {
      const id = el.dataset.ruleId;
      if (seen.has(id)) return;
      seen.add(id);
      out.push(el);
    });
    return out;
  }

  // Memoria del último cálculo. La usamos para flash-animar sólo los valores
  // que efectivamente cambiaron y así dar retroalimentación clara al
  // usuario cuando importa veredictos o marca reglas: el problema reportado
  // por evaluadores fue "los porcentajes no se actualizan" cuando en
  // realidad sí lo hacían, pero el cambio era silencioso.
  let lastCalc = null;

  function flash(el) {
    if (!el) return;
    el.classList.remove('flash');
    // Forzar reflow para reiniciar la animación si se dispara dos veces seguidas
    void el.offsetWidth;
    el.classList.add('flash');
  }

  function recalc(opts) {
    const flashOnChange = !!(opts && opts.flash);
    const domainAcc = {}; // domain -> {num, den, cumple, parcial, nocumple, noeval, evaluated}
    let globalNum = 0, globalDen = 0;
    let totalRules = 0, autoEval = 0, manualEval = 0;
    let apto = true;
    let criticalFails = 0;

    uniqueRules().forEach(el => {
      const dom    = el.dataset.domain;
      const sev    = parseInt(el.dataset.severity, 10) || 1;
      const crit   = el.dataset.critical === "true";
      const status = getRuleEffectiveStatus(el);
      const fromHuman = !!verdicts[el.dataset.ruleId];

      if (!domainAcc[dom]) {
        domainAcc[dom] = {num:0, den:0, cumple:0, parcial:0, nocumple:0, noeval:0, total:0, evaluated:0};
      }
      domainAcc[dom].total++;
      totalRules++;

      const c = statusToNumeric(status);
      if (c === null) {
        domainAcc[dom].noeval++;
      } else {
        const dw = DOMAIN_WEIGHTS[dom] || 1.0;
        domainAcc[dom].num += c * sev;
        domainAcc[dom].den += sev;
        globalNum += c * sev * dw;
        globalDen += sev * dw;
        domainAcc[dom].evaluated++;

        if (status === "cumple")        domainAcc[dom].cumple++;
        else if (status === "parcial")  domainAcc[dom].parcial++;
        else if (status === "nocumple") {
          domainAcc[dom].nocumple++;
          if (crit) { apto = false; criticalFails++; }
        }

        if (fromHuman) manualEval++;
        else            autoEval++;
      }
    });

    // === Actualizar score global y cobertura ===
    const globalScore = globalDen > 0 ? (100 * globalNum / globalDen) : 0;
    const coverage    = totalRules > 0 ? (100 * (autoEval + manualEval) / totalRules) : 0;
    const autoCovPct  = totalRules > 0 ? (100 * autoEval   / totalRules) : 0;
    const manCovPct   = totalRules > 0 ? (100 * manualEval / totalRules) : 0;

    // Detectar diff vs. último cálculo para flash-animar sólo los campos que
    // cambiaron. Comparamos con tolerancia 0.05 para no flash-ear ruido por
    // redondeo en el .toFixed(1).
    const changed = (a, b) => Math.abs((a||0) - (b||0)) > 0.05;
    const hadPrev = lastCalc !== null;

    setText("global-score-value", globalScore.toFixed(1));
    setClass("global-score-num", "score-num " + scoreClass(globalScore));
    setText("coverage-value",   coverage.toFixed(1));
    setText("auto-coverage",    autoCovPct.toFixed(1));
    setText("manual-coverage",  manCovPct.toFixed(1));
    setText("evaluated-count",  String(autoEval + manualEval));

    if (flashOnChange && hadPrev) {
      if (changed(lastCalc.globalScore, globalScore)) flash(document.getElementById("global-score-num"));
      if (changed(lastCalc.coverage,    coverage))    flash(document.getElementById("coverage-value"));
      if (changed(lastCalc.autoCovPct,  autoCovPct))  flash(document.getElementById("auto-coverage"));
      if (changed(lastCalc.manCovPct,   manCovPct))   flash(document.getElementById("manual-coverage"));
      if (lastCalc.evaluated !== (autoEval + manualEval)) flash(document.getElementById("evaluated-count"));
    }

    // === Actualizar score por dominio ===
    const prevDomains = (lastCalc && lastCalc.domains) || {};
    const newDomains = {};
    document.querySelectorAll('.domain-row').forEach(row => {
      const d = row.dataset.domain;
      const acc = domainAcc[d];
      if (!acc) return;
      const ds = acc.den > 0 ? (100 * acc.num / acc.den) : 0;
      newDomains[d] = ds;
      const cls = scoreClass(ds);
      const sEl = row.querySelector('[data-domain-score]');
      const bEl = row.querySelector('[data-bar]');
      if (sEl) {
        sEl.textContent = ds.toFixed(2);
        sEl.className = "domain-score " + cls;
      }
      if (bEl) {
        bEl.style.width = Math.max(0, Math.min(100, ds)) + "%";
        bEl.className = "bar-fill " + cls;
      }
      if (flashOnChange && hadPrev && changed(prevDomains[d], ds)) {
        flash(sEl);
      }
      const cp = row.querySelector('[data-c-pass]');
      const cP = row.querySelector('[data-c-partial]');
      const cf = row.querySelector('[data-c-fail]');
      const cn = row.querySelector('[data-c-pend]');
      if (cp) cp.textContent = "✓ " + acc.cumple;
      if (cP) cP.textContent = "◐ " + acc.parcial;
      if (cf) cf.textContent = "✗ " + acc.nocumple;
      if (cn) cn.textContent = "? " + acc.noeval;
    });

    // === Actualizar aptitud ===
    const aptBox  = document.getElementById("aptitud-box");
    const aptDesc = document.getElementById("aptitud-desc");
    if (aptBox && aptDesc) {
      if (apto) {
        aptBox.className = "aptitud apto";
        aptBox.innerHTML = '<span class="label">✓ APTO</span><span class="desc" id="aptitud-desc">No hay SVR críticas en estado \'no cumple\'.</span>';
      } else {
        aptBox.className = "aptitud no-apto";
        aptBox.innerHTML = '<span class="label">✗ NO APTO</span><span class="desc" id="aptitud-desc">Existen ' + criticalFails + ' regla(s) crítica(s) en estado \'no cumple\'.</span>';
      }
    }

    // === Actualizar progreso del centro de revisión ===
    const totalManualSlots = document.querySelectorAll('[data-can-review="true"]').length / countDuplicates();
    const reviewedCount = Object.keys(verdicts).length;
    setText("manual-progress-current", String(reviewedCount));
    const totalEl = document.getElementById("manual-progress-total");
    const total = totalEl ? parseInt(totalEl.textContent, 10) || 1 : 1;
    const pct = Math.min(100, 100 * reviewedCount / total);
    const fill = document.getElementById("manual-progress-fill");
    if (fill) fill.style.width = pct + "%";
    if (flashOnChange && hadPrev && lastCalc.reviewedCount !== reviewedCount) {
      flash(document.getElementById("manual-progress-current"));
    }

    // Guardar último cálculo para detectar cambios en la próxima corrida.
    lastCalc = {
      globalScore: globalScore,
      coverage: coverage,
      autoCovPct: autoCovPct,
      manCovPct: manCovPct,
      evaluated: autoEval + manualEval,
      reviewedCount: reviewedCount,
      domains: newDomains
    };
  }

  // Las rule cards pueden aparecer en varias secciones; este factor ajusta
  // el conteo de slots manuales para evitar contar duplicados.
  function countDuplicates() {
    const ids = new Set();
    let dupes = 0;
    document.querySelectorAll('[data-can-review="true"]').forEach(el => {
      const id = el.dataset.ruleId;
      if (ids.has(id)) dupes++;
      else ids.add(id);
    });
    return Math.max(1, (dupes + ids.size) / Math.max(1, ids.size));
  }

  // ====================================================================
  // Manejo de los botones de veredicto
  // ====================================================================
  function applyVerdict(ruleId, verdict) {
    if (verdict === "naplica") {
      // "no aplica" no entra al cálculo (igual que falta-evidencia) pero
      // sí queda registrado para exportarlo en el archivo de revisión y
      // ser visible en el reporte.
      verdicts[ruleId] = { status: null, raw: "naplica", evidence: getEvidence(ruleId) };
    } else if (verdict === null) {
      delete verdicts[ruleId];
    } else {
      verdicts[ruleId] = { status: verdict, raw: verdict, evidence: getEvidence(ruleId) };
    }
    paintRule(ruleId);
    recalc({ flash: true });
  }

  function getEvidence(ruleId) {
    // Toma la evidencia del primer textarea encontrado para esa regla
    const el = document.querySelector('[data-rule-id="' + cssEscape(ruleId) + '"] [data-evidence-input]');
    return el ? el.value : "";
  }

  function paintRule(ruleId) {
    document.querySelectorAll('[data-rule-id="' + cssEscape(ruleId) + '"]').forEach(card => {
      const v = verdicts[ruleId];
      const badge = card.querySelector('[data-status-badge]');
      const tag   = card.querySelector('[data-reviewed-tag]');
      // Reset estado de botones
      card.querySelectorAll('.verdict-btn').forEach(b => b.classList.remove('active','cumple','parcial','nocumple','naplica'));
      if (!v) {
        // Volver al estado inicial
        if (badge) {
          badge.textContent = card.dataset.initialStatusLabel || badge.textContent;
        }
        if (tag) tag.style.display = "none";
        card.classList.remove("reviewed");
        return;
      }
      const raw = v.raw;
      const target = card.querySelector('.verdict-btn[data-verdict="' + raw + '"]');
      if (target) target.classList.add('active', raw);
      if (badge) {
        const labels = {cumple:"Cumple", parcial:"Cumple parcialmente", nocumple:"No cumple", naplica:"No aplica"};
        badge.textContent = labels[raw] || badge.textContent;
        const clsMap = {cumple:"badge pass", parcial:"badge partial", nocumple:"badge fail", naplica:"badge manual"};
        badge.className = clsMap[raw] || badge.className;
      }
      if (tag) tag.style.display = "";
      card.classList.add("reviewed");
    });
  }

  // Función polyfill ligera para CSS.escape (para IDs como "SVR-NET-01"
  // que no necesitan escape, pero es buena práctica defensiva).
  function cssEscape(s) {
    if (typeof CSS !== 'undefined' && CSS.escape) return CSS.escape(s);
    return String(s).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
  }

  // ====================================================================
  // Exportación / Importación del archivo de revisión (YAML)
  // ====================================================================
  function exportReview() {
    const lines = [];
    lines.push('# Archivo de revisión manual generado por Staging Shield');
    lines.push('# Entorno: ' + (ENV_META.name || '?') + ' (' + (ENV_META.type || '?') + ')');
    lines.push('# Reusar con: staging-shield scan --review este_archivo.yaml');
    lines.push('reviewer: ""');
    lines.push('timestamp: "' + new Date().toISOString() + '"');
    lines.push('verdicts:');
    const ids = Object.keys(verdicts).sort();
    if (ids.length === 0) {
      lines.push('  # (sin veredictos registrados)');
    }
    for (const id of ids) {
      const v = verdicts[id];
      const statusStr = v.raw; // "cumple" | "parcial" -> "cumple_parcial" | "nocumple" -> "no_cumple"
      const yamlStatus = (statusStr === "parcial")  ? "cumple_parcial"
                        : (statusStr === "nocumple") ? "no_cumple"
                        : (statusStr === "naplica")  ? "no_aplica"
                        : statusStr;
      lines.push('  ' + id + ':');
      lines.push('    status: ' + yamlStatus);
      const ev = (v.evidence || "").replace(/\r?\n/g, ' ').replace(/"/g, '\\"');
      if (ev) lines.push('    evidence: "' + ev + '"');
    }
    const yaml = lines.join('\n') + '\n';
    download("staging-shield-review-" + slug(ENV_META.name) + ".yaml", yaml, "text/yaml");
    toast("Revisión exportada (" + ids.length + " veredictos)", "success");
  }

  function importReview(file) {
    const reader = new FileReader();
    reader.onload = function() {
      try {
        const txt = String(reader.result || "");
        const parsed = parseSimpleYAML(txt);
        if (!parsed.verdicts || Object.keys(parsed.verdicts).length === 0) {
          throw new Error("el archivo no contiene veredictos. Revise que tenga la sección 'verdicts:' al principio.");
        }
        let n = 0, skipped = 0, unknown = [];
        const knownIds = new Set();
        document.querySelectorAll('[data-rule-id]').forEach(el => knownIds.add(el.dataset.ruleId));

        for (const id in parsed.verdicts) {
          const v = parsed.verdicts[id];
          let raw = (v.status || "").toLowerCase();
          if (raw === "cumple_parcial" || raw === "parcial") raw = "parcial";
          else if (raw === "no_cumple" || raw === "nocumple") raw = "nocumple";
          else if (raw === "no_aplica" || raw === "naplica") raw = "naplica";
          if (!["cumple","parcial","nocumple","naplica"].includes(raw)) {
            skipped++; continue;
          }
          if (!knownIds.has(id)) {
            unknown.push(id); continue;
          }
          if (raw === "naplica") {
            verdicts[id] = { status: null, raw: "naplica", evidence: v.evidence || "" };
          } else {
            verdicts[id] = { status: raw, raw: raw, evidence: v.evidence || "" };
          }
          document.querySelectorAll('[data-rule-id="' + cssEscape(id) + '"] [data-evidence-input]').forEach(t => {
            t.value = v.evidence || "";
          });
          paintRule(id);
          n++;
        }
        recalc({ flash: true });

        // Mensaje claro al usuario sobre el resultado del import. Se incluye
        // explícitamente el delta de score para que el evaluador entienda
        // que sí se actualizaron los porcentajes y no solo las tarjetas de
        // abajo. Este fue el feedback principal de los usuarios iniciales.
        let msg;
        if (n > 0 && lastCalc) {
          msg = "✓ " + n + " veredictos aplicados — Score " + lastCalc.globalScore.toFixed(1) +
                " · Cobertura " + lastCalc.coverage.toFixed(1) + "%";
        } else {
          msg = "Importados " + n + " veredictos";
        }
        const tail = [];
        if (skipped > 0)        tail.push(skipped + " ignorados por status inválido");
        if (unknown.length > 0) tail.push(unknown.length + " IDs desconocidos: " + unknown.slice(0,3).join(", ") + (unknown.length > 3 ? "..." : ""));
        if (parsed.__issues && parsed.__issues.length > 0) tail.push(parsed.__issues.length + " problemas de formato");
        if (tail.length > 0) msg += " (" + tail.join("; ") + ")";
        toast(msg, n > 0 ? "success" : "error");
        if (n === 0) console.warn("Import sin efecto. Diagnóstico:", parsed.__issues);
      } catch (e) {
        toast("Error al importar: " + e.message, "error");
      }
    };
    reader.readAsText(file);
  }

  function resetReview() {
    if (!confirm("¿Limpiar todos los veredictos manuales? Esta acción no se puede deshacer en esta vista (se conservan en el archivo exportado).")) return;
    const ids = Object.keys(verdicts);
    for (const id of ids) {
      delete verdicts[id];
      paintRule(id);
    }
    document.querySelectorAll('[data-evidence-input]').forEach(t => t.value = "");
    recalc({ flash: true });
    toast("Veredictos limpiados", "success");
  }

  // Parser tolerante para el subset de YAML que produce el centro de
  // revisión. Acepta indentación arbitraria con espacios o tabs siempre y
  // cuando sea consistente dentro de cada bloque, y soporta los formatos
  // tanto exportado por nosotros como editado a mano. Devuelve además
  // diagnóstico: número de líneas ignoradas y problemas encontrados, para
  // que el usuario sepa por qué un import puede haber resultado en menos
  // veredictos de los esperados.
  function parseSimpleYAML(txt) {
    const out = { verdicts: {} };
    const issues = [];
    const lines = txt.split(/\r?\n/);
    let inVerdicts = false;
    let baseIndent = -1;     // indent de los IDs dentro de 'verdicts:'
    let fieldIndent = -1;    // indent de los campos dentro de cada ID
    let currentId = null;

    function indentOf(s) {
      let n = 0;
      for (const ch of s) {
        if (ch === ' ') n += 1;
        else if (ch === '\t') n += 2; // tratar tab como 2 espacios
        else break;
      }
      return n;
    }

    for (let i = 0; i < lines.length; i++) {
      const raw = lines[i];
      if (/^\s*#/.test(raw) || /^\s*$/.test(raw)) continue;
      const indent = indentOf(raw);
      const trimmed = raw.replace(/^\s+/, '').replace(/\s+$/, '');

      // Top-level key (incluyendo 'verdicts:')
      if (indent === 0) {
        if (/^verdicts\s*:\s*$/.test(trimmed)) {
          inVerdicts = true;
          baseIndent = -1;
          fieldIndent = -1;
          currentId = null;
          continue;
        }
        // Otros campos top-level: reviewer, timestamp, etc.
        const m = trimmed.match(/^([a-zA-Z_][a-zA-Z0-9_]*)\s*:\s*"?(.*?)"?\s*$/);
        if (m) out[m[1]] = m[2];
        inVerdicts = false;
        continue;
      }

      if (!inVerdicts) continue;

      // Detectar el indent base de los IDs la primera vez que aparece uno
      if (baseIndent === -1) baseIndent = indent;

      // Línea de ID nuevo: "  SVR-XXX-NN:"
      if (indent === baseIndent && /^[A-Za-z][A-Za-z0-9_\-]*\s*:\s*$/.test(trimmed)) {
        currentId = trimmed.replace(/\s*:\s*$/, '');
        out.verdicts[currentId] = {};
        fieldIndent = -1;
        continue;
      }

      // Línea de campo: "    status: cumple" / "    evidence: ..."
      if (indent > baseIndent && currentId) {
        if (fieldIndent === -1) fieldIndent = indent;
        if (indent === fieldIndent) {
          const m = trimmed.match(/^([a-zA-Z_][a-zA-Z0-9_]*)\s*:\s*(.*?)\s*$/);
          if (m) {
            let val = m[2];
            // Quitar comillas envolventes (simples o dobles), si están balanceadas
            if ((val.startsWith('"') && val.endsWith('"') && val.length >= 2) ||
                (val.startsWith("'") && val.endsWith("'") && val.length >= 2)) {
              val = val.slice(1, -1);
            }
            // Des-escape básico para evidence con \" y \n
            val = val.replace(/\\"/g, '"').replace(/\\n/g, '\n').replace(/\\\\/g, '\\');
            out.verdicts[currentId][m[1]] = val;
          } else {
            issues.push("línea " + (i+1) + ": no se pudo parsear el campo");
          }
        } else {
          issues.push("línea " + (i+1) + ": indentación inconsistente, ignorada");
        }
        continue;
      }

      // Algo no encajó
      issues.push("línea " + (i+1) + ": fuera de estructura, ignorada");
    }
    out.__issues = issues;
    return out;
  }

  // ====================================================================
  // Helpers DOM
  // ====================================================================
  function setText(id, txt) { const el = document.getElementById(id); if (el) el.textContent = txt; }
  function setClass(id, cls) { const el = document.getElementById(id); if (el) el.className = cls; }

  function slug(s) {
    return String(s||"env").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
  }

  function download(filename, content, mime) {
    const blob = new Blob([content], { type: mime || "text/plain" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  }

  let toastTimeout = null;
  function toast(msg, kind) {
    const t = document.getElementById("toast");
    if (!t) return;
    t.textContent = msg;
    t.className = "toast show " + (kind || "");
    if (toastTimeout) clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => { t.className = "toast"; }, 3000);
  }

  // ====================================================================
  // Wiring
  // ====================================================================
  document.addEventListener("click", function(e) {
    const btn = e.target.closest('.verdict-btn');
    if (!btn) return;
    const id = btn.dataset.ruleTarget;
    const v  = btn.dataset.verdict;
    // Toggle: clic sobre un botón ya activo lo desactiva
    if (verdicts[id] && verdicts[id].raw === v) {
      applyVerdict(id, null);
    } else {
      applyVerdict(id, v);
    }
  });

  // Sincronizar evidencia entre cards duplicadas (mismo ID en distintas
  // secciones) y persistirla en el objeto verdicts.
  document.addEventListener("input", function(e) {
    const t = e.target;
    if (!t.matches || !t.matches('[data-evidence-input]')) return;
    const card = t.closest('[data-rule-id]');
    if (!card) return;
    const id = card.dataset.ruleId;
    document.querySelectorAll('[data-rule-id="' + cssEscape(id) + '"] [data-evidence-input]').forEach(other => {
      if (other !== t) other.value = t.value;
    });
    if (verdicts[id]) verdicts[id].evidence = t.value;
  });

  const btnExp = document.getElementById("btn-export-review");
  if (btnExp) btnExp.addEventListener("click", exportReview);
  const btnReset = document.getElementById("btn-reset-review");
  if (btnReset) btnReset.addEventListener("click", resetReview);
  const fileImp = document.getElementById("file-import-review");
  if (fileImp) fileImp.addEventListener("change", function(e) {
    const f = e.target.files && e.target.files[0];
    if (f) importReview(f);
    e.target.value = ""; // permitir reimportar el mismo archivo
  });

  // Capturar la etiqueta inicial de cada badge para poder restaurarla al
  // limpiar un veredicto.
  document.querySelectorAll('[data-rule-id]').forEach(card => {
    const badge = card.querySelector('[data-status-badge]');
    if (badge) card.dataset.initialStatusLabel = badge.textContent;
  });

  // Cálculo inicial (refleja estado actual sin veredictos manuales)
  recalc();
})();
</script>
</body>
</html>
