<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Staging Shield · {{.Env.EnvironmentName}} · {{.Env.Timestamp.Format "2006-01-02"}}</title>
<style>
  :root {
    --bg: #0f1419;
    --bg-card: #1a212b;
    --bg-card-2: #232b37;
    --border: #2c3644;
    --text: #e6edf3;
    --text-dim: #9aa6b2;
    --accent: #4f9cf9;
    --good: #3fb950;
    --warn: #d29922;
    --bad: #f85149;
    --critical: #ff5e5e;
    --high: #f85149;
    --med: #d29922;
    --low: #8b9aa8;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5;
  }
  .wrap { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }
  header { border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 24px; }
  header h1 { margin: 0 0 4px; font-size: 24px; letter-spacing: 0.2px; }
  header h1 .pill { font-size: 11px; padding: 3px 8px; border-radius: 999px; background: var(--accent); color: #fff; vertical-align: middle; margin-left: 8px; font-weight: 600; }
  header .meta { color: var(--text-dim); font-size: 13px; }
  header .meta span { margin-right: 16px; }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }
  .card h2 { margin: 0 0 12px; font-size: 16px; color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 8px; }

  .global-score {
    display: flex; align-items: center; gap: 24px;
  }
  .score-num {
    font-size: 56px; font-weight: 700; line-height: 1;
  }
  .score-num.score-good { color: var(--good); }
  .score-num.score-warn { color: var(--warn); }
  .score-num.score-bad  { color: var(--bad); }
  .score-of { color: var(--text-dim); font-size: 18px; font-weight: 400; }

  .aptitud {
    padding: 14px 16px; border-radius: 8px; font-weight: 600;
    display: flex; align-items: center; gap: 10px;
  }
  .aptitud.apto    { background: rgba(63, 185, 80, 0.12); color: var(--good); border: 1px solid rgba(63,185,80,0.3); }
  .aptitud.no-apto { background: rgba(248, 81, 73, 0.12); color: var(--bad);  border: 1px solid rgba(248,81,73,0.3); }
  .aptitud .label { font-size: 18px; }
  .aptitud .desc  { font-weight: 400; color: var(--text-dim); margin-left: 8px; font-size: 13px; }

  .domain-row {
    display: grid;
    grid-template-columns: 1fr 100px 80px 200px;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .domain-row:last-child { border-bottom: none; }
  .domain-name { font-weight: 500; }
  .domain-score { font-size: 18px; font-weight: 700; text-align: right; }
  .domain-score.score-good { color: var(--good); }
  .domain-score.score-warn { color: var(--warn); }
  .domain-score.score-bad  { color: var(--bad); }
  .bar-wrap {
    height: 8px; background: var(--border); border-radius: 4px; overflow: hidden;
  }
  .bar-fill { height: 100%; background: var(--accent); border-radius: 4px; }
  .bar-fill.score-good { background: var(--good); }
  .bar-fill.score-warn { background: var(--warn); }
  .bar-fill.score-bad  { background: var(--bad); }
  .domain-counts { font-size: 12px; color: var(--text-dim); text-align: right; }
  .domain-counts span { display: inline-block; margin-left: 8px; }
  .domain-counts .c-pass    { color: var(--good); }
  .domain-counts .c-partial { color: var(--warn); }
  .domain-counts .c-fail    { color: var(--bad); }
  .domain-counts .c-pend    { color: var(--text-dim); }

  section { margin-bottom: 32px; }
  section > h2 {
    font-size: 18px; margin: 0 0 16px;
    padding-bottom: 8px; border-bottom: 2px solid var(--border);
  }
  section > h2 .count { color: var(--text-dim); font-weight: 400; font-size: 14px; margin-left: 8px; }

  .rule {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px;
    border-left: 4px solid var(--border);
  }
  .rule.high     { border-left-color: var(--high); }
  .rule.med      { border-left-color: var(--med); }
  .rule.low      { border-left-color: var(--low); }
  .rule.critical { border-left-color: var(--critical); background: rgba(255, 94, 94, 0.05); }

  .rule-head {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: 8px; margin-bottom: 8px;
  }
  .rule-id {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-weight: 700;
    background: var(--bg-card-2);
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 13px;
  }
  .rule-criterion { font-weight: 500; flex: 1; min-width: 300px; }
  .rule-meta {
    display: flex; gap: 12px; flex-wrap: wrap;
    color: var(--text-dim); font-size: 12px;
    margin-bottom: 8px;
  }
  .rule-meta span { padding: 2px 0; }

  .badge {
    display: inline-block; padding: 2px 8px; border-radius: 999px;
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .badge.high     { background: rgba(248,81,73,0.18);  color: #ff8a82; }
  .badge.med      { background: rgba(210,153,34,0.18); color: #f0b945; }
  .badge.low      { background: rgba(139,154,168,0.18); color: var(--low); }
  .badge.pass     { background: rgba(63,185,80,0.18);  color: var(--good); }
  .badge.partial  { background: rgba(210,153,34,0.18); color: #f0b945; }
  .badge.fail     { background: rgba(248,81,73,0.18);  color: #ff8a82; }
  .badge.missing  { background: rgba(79,156,249,0.18); color: var(--accent); }
  .badge.manual   { background: rgba(154,166,178,0.18); color: var(--text-dim); }
  .badge.critical { background: rgba(255,94,94,0.25);  color: var(--critical); border: 1px solid rgba(255,94,94,0.5); }

  .evidence {
    background: var(--bg-card-2); border-radius: 6px; padding: 10px 12px;
    font-size: 13px; color: var(--text); margin-top: 8px;
  }
  .evidence .label { color: var(--text-dim); font-weight: 600; margin-right: 6px; }
  .notes {
    margin-top: 6px; font-size: 12px; color: var(--text-dim); font-style: italic;
  }

  table.discovery-table {
    width: 100%; border-collapse: collapse; font-size: 13px;
  }
  table.discovery-table th, table.discovery-table td {
    text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--border);
  }
  table.discovery-table th { color: var(--text-dim); font-weight: 600; font-size: 12px; text-transform: uppercase; }
  table.discovery-table tr:last-child td { border-bottom: none; }

  .recos { list-style: none; padding: 0; margin: 0; }
  .recos li {
    padding: 10px 14px;
    background: var(--bg-card-2);
    border-radius: 6px;
    margin-bottom: 8px;
    border-left: 3px solid var(--accent);
  }

  .footer { margin-top: 40px; padding-top: 16px; border-top: 1px solid var(--border); color: var(--text-dim); font-size: 12px; text-align: center; }
  details summary { cursor: pointer; padding: 8px 0; font-weight: 500; }
  details summary:hover { color: var(--accent); }

  code { font-family: ui-monospace, "SF Mono", Menlo, monospace; background: var(--bg-card-2); padding: 1px 5px; border-radius: 3px; font-size: 12px; }

  @media (max-width: 800px) {
    .grid { grid-template-columns: 1fr; }
    .domain-row { grid-template-columns: 1fr; }
    .domain-counts { text-align: left; }
  }
</style>
</head>
<body>
<div class="wrap">

<header>
  <h1>Staging Shield <span class="pill">{{.Env.EnvironmentType}}</span></h1>
  <div class="meta">
    <span><strong>Entorno:</strong> {{.Env.EnvironmentName}}</span>
    <span><strong>Stack:</strong> {{.Env.StackType}}</span>
    <span><strong>Objetivo:</strong> {{.Env.Target}}</span>
    {{if .Env.IPAddress}}<span><strong>IP:</strong> {{.Env.IPAddress}}</span>{{end}}
    <span><strong>Evaluado:</strong> {{.Env.Timestamp.Format "2006-01-02 15:04:05"}}</span>
  </div>
</header>

<div class="grid">
  <div class="card">
    <h2>Security Score Global</h2>
    <div class="global-score">
      <div class="score-num {{if ge .Stats.GlobalScore 80.0}}score-good{{else if ge .Stats.GlobalScore 60.0}}score-warn{{else}}score-bad{{end}}">
        {{printf "%.1f" .Stats.GlobalScore}}<span class="score-of"> / 100</span>
      </div>
      <div>
        <div style="color: var(--text-dim); font-size: 13px;">Reglas evaluadas: {{.Stats.TotalRules}}</div>
        <div style="color: var(--text-dim); font-size: 13px;">Cobertura automática: {{printf "%.1f" .Stats.AutoCoverage}}%</div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Aptitud para promoción</h2>
    {{if .Stats.Apto}}
      <div class="aptitud apto">
        <span class="label">✓ APTO</span>
        <span class="desc">No hay SVR críticas en estado 'no cumple'.</span>
      </div>
    {{else}}
      <div class="aptitud no-apto">
        <span class="label">✗ NO APTO</span>
        <span class="desc">Existen {{len .Stats.CriticalFailures}} regla(s) crítica(s) en estado 'no cumple'.</span>
      </div>
    {{end}}
  </div>
</div>

<div class="card" style="margin-bottom: 32px;">
  <h2>Score por dominio</h2>
  {{range .DomainList}}
  <div class="domain-row">
    <div class="domain-name">{{.Name}}</div>
    <div class="bar-wrap">
      <div class="bar-fill {{.BadgeCls}}" style="width: {{.BarPct}}%"></div>
    </div>
    <div class="domain-score {{.BadgeCls}}">{{.ScoreStr}}</div>
    <div class="domain-counts">
      <span class="c-pass">✓ {{.Cumple}}</span>
      <span class="c-partial">◐ {{.Parcial}}</span>
      <span class="c-fail">✗ {{.NoCumple}}</span>
      <span class="c-pend">? {{.NoEval}}</span>
    </div>
  </div>
  {{end}}
</div>

{{if .CriticalView}}
<section>
  <h2>SVR críticas que bloquean la promoción <span class="count">({{len .CriticalView}})</span></h2>
  {{range .CriticalView}}
  <div class="rule critical">
    <div class="rule-head">
      <span class="rule-id">{{.ID}}</span>
      <span class="badge critical">crítica</span>
      <span class="badge {{.SevClass}}">{{.Severity}}</span>
      <span class="badge {{.StatusCls}}">{{.Status}}</span>
      <span class="rule-criterion">{{.Criterion}}</span>
    </div>
    <div class="rule-meta">
      <span>Dominio: {{.Domain}}</span>
      <span>Referencia: <code>{{.Reference}}</code></span>
      <span>Modo: {{.Mode}}</span>
    </div>
    {{if .Evidence}}<div class="evidence"><span class="label">Evidencia:</span>{{.Evidence}}</div>{{end}}
    {{if .Notes}}<div class="notes">↳ {{.Notes}}</div>{{end}}
  </div>
  {{end}}
</section>
{{end}}

{{if .Recommendations}}
<section>
  <h2>Recomendaciones priorizadas</h2>
  <ul class="recos">
    {{range .Recommendations}}<li>{{.}}</li>{{end}}
  </ul>
</section>
{{end}}

{{if .FailedView}}
<section>
  <h2>Hallazgos: SVR en estado "no cumple" <span class="count">({{len .FailedView}})</span></h2>
  {{range .FailedView}}
  <div class="rule {{.SevClass}}{{if .Critical}} critical{{end}}">
    <div class="rule-head">
      <span class="rule-id">{{.ID}}</span>
      <span class="badge {{.SevClass}}">{{.Severity}}</span>
      <span class="badge {{.StatusCls}}">{{.Status}}</span>
      {{if .Critical}}<span class="badge critical">crítica</span>{{end}}
      <span class="rule-criterion">{{.Criterion}}</span>
    </div>
    <div class="rule-meta">
      <span>Dominio: {{.Domain}}</span>
      <span>Referencia: <code>{{.Reference}}</code></span>
      <span>Modo: {{.Mode}}</span>
    </div>
    {{if .Evidence}}<div class="evidence"><span class="label">Evidencia:</span>{{.Evidence}}</div>{{end}}
    {{if .Notes}}<div class="notes">↳ {{.Notes}}</div>{{end}}
  </div>
  {{end}}
</section>
{{end}}

{{if .NoEvidenceView}}
<section>
  <h2>Reglas con evidencia incompleta <span class="count">({{len .NoEvidenceView}})</span></h2>
  <p style="color: var(--text-dim); margin-bottom: 12px;">
    Estas reglas no se pudieron evaluar automáticamente porque la configuración de entrada del programa cliente no incluye los datos necesarios.
    No se computan en el score global y deben completarse para una evaluación más precisa.
  </p>
  {{range .NoEvidenceView}}
  <div class="rule low">
    <div class="rule-head">
      <span class="rule-id">{{.ID}}</span>
      <span class="badge {{.SevClass}}">{{.Severity}}</span>
      <span class="badge {{.StatusCls}}">{{.Status}}</span>
      <span class="rule-criterion">{{.Criterion}}</span>
    </div>
    <div class="rule-meta">
      <span>Dominio: {{.Domain}}</span>
      <span>Referencia: <code>{{.Reference}}</code></span>
    </div>
    {{if .Notes}}<div class="notes">↳ {{.Notes}}</div>{{end}}
  </div>
  {{end}}
</section>
{{end}}

{{if .ManualView}}
<section>
  <h2>Reglas que requieren revisión manual <span class="count">({{len .ManualView}})</span></h2>
  <p style="color: var(--text-dim); margin-bottom: 12px;">
    Estas reglas requieren revisión documental, validación de procesos organizacionales o acceso administrativo que el programa cliente no tiene.
    El evaluador debe completar su valoración manualmente.
  </p>
  {{range .ManualView}}
  <div class="rule low">
    <div class="rule-head">
      <span class="rule-id">{{.ID}}</span>
      <span class="badge {{.SevClass}}">{{.Severity}}</span>
      <span class="badge {{.StatusCls}}">manual</span>
      <span class="rule-criterion">{{.Criterion}}</span>
    </div>
    <div class="rule-meta">
      <span>Dominio: {{.Domain}}</span>
      <span>Referencia: <code>{{.Reference}}</code></span>
    </div>
  </div>
  {{end}}
</section>
{{end}}

{{if .PassedView}}
<section>
  <details>
    <summary>SVR cumplidas (total o parcialmente) <span class="count">({{len .PassedView}})</span></summary>
    {{range .PassedView}}
    <div class="rule low">
      <div class="rule-head">
        <span class="rule-id">{{.ID}}</span>
        <span class="badge {{.SevClass}}">{{.Severity}}</span>
        <span class="badge {{.StatusCls}}">{{.Status}}</span>
        <span class="rule-criterion">{{.Criterion}}</span>
      </div>
      <div class="rule-meta">
        <span>Dominio: {{.Domain}}</span>
        <span>Referencia: <code>{{.Reference}}</code></span>
      </div>
      {{if .Evidence}}<div class="evidence"><span class="label">Evidencia:</span>{{.Evidence}}</div>{{end}}
    </div>
    {{end}}
  </details>
</section>
{{end}}

<section>
  <h2>Evidencia técnica recopilada</h2>
  <details open>
    <summary>Resolución DNS y conectividad</summary>
    <table class="discovery-table">
      <tr><th>Item</th><th>Resultado</th></tr>
      {{if .Discovery.DNSError}}
      <tr><td>DNS error</td><td>{{.Discovery.DNSError}}</td></tr>
      {{else}}
      <tr><td>IPs resueltas</td><td>{{join .Discovery.DNSResolved ", "}}</td></tr>
      {{end}}
      {{if .Discovery.HTTPStatus}}
      <tr><td>HTTP status</td><td>{{.Discovery.HTTPStatus}}</td></tr>
      {{end}}
    </table>
  </details>

  <details open>
    <summary>Puertos abiertos detectados ({{len .OpenPortsList}})</summary>
    {{if .OpenPortsList}}
    <table class="discovery-table">
      <tr><th>Puerto</th><th>Banner</th></tr>
      {{range .Discovery.OpenPorts}}
      <tr><td><code>{{.Port}}</code></td><td>{{if .Banner}}{{.Banner}}{{else}}(sin banner){{end}}</td></tr>
      {{end}}
    </table>
    <p style="margin-top: 12px; color: var(--text-dim);">
      Esperados: {{intCSV .Env.ExpectedPorts}}<br>
      Inesperados: {{intCSV .Discovery.UnexpectedPorts}}<br>
      Declarados pero no abiertos: {{intCSV .Discovery.MissingPorts}}
    </p>
    {{else}}
    <p style="color: var(--text-dim);">No se detectaron puertos abiertos en la lista probada.</p>
    {{end}}
  </details>

  {{if .Discovery.TLS.Tested}}
  <details>
    <summary>TLS</summary>
    <table class="discovery-table">
      <tr><th>Item</th><th>Valor</th></tr>
      <tr><td>Disponible</td><td>{{.Discovery.TLS.Available}}</td></tr>
      {{if .Discovery.TLS.Available}}
      <tr><td>Versión</td><td>{{.Discovery.TLS.Version}}</td></tr>
      <tr><td>Cipher Suite</td><td>{{.Discovery.TLS.CipherSuite}}</td></tr>
      <tr><td>TLS 1.3</td><td>{{.Discovery.TLS.IsTLS13}}</td></tr>
      <tr><td>Subject</td><td>{{.Discovery.TLS.CertSubject}}</td></tr>
      <tr><td>Issuer</td><td>{{.Discovery.TLS.CertIssuer}}</td></tr>
      <tr><td>NotAfter</td><td>{{.Discovery.TLS.NotAfter.Format "2006-01-02"}}</td></tr>
      <tr><td>Expirado</td><td>{{.Discovery.TLS.IsExpired}}</td></tr>
      {{else}}
      <tr><td>Error</td><td>{{.Discovery.TLS.Error}}</td></tr>
      {{end}}
    </table>
  </details>
  {{end}}

  {{if .Discovery.HTTPHeaders}}
  <details>
    <summary>Encabezados HTTP de respuesta</summary>
    <table class="discovery-table">
      <tr><th>Encabezado</th><th>Valor</th></tr>
      {{range .Discovery.HTTPHeaders}}
      <tr><td><code>{{.Name}}</code></td><td>{{.Value}}</td></tr>
      {{end}}
    </table>
  </details>
  {{end}}

  {{if .Discovery.AdminExposed}}
  <details open>
    <summary>Interfaces administrativas potencialmente expuestas</summary>
    <table class="discovery-table">
      <tr><th>Puerto</th><th>Servicio</th></tr>
      {{range .Discovery.AdminExposed}}
      <tr><td><code>{{.Port}}</code></td><td>{{.Description}}</td></tr>
      {{end}}
    </table>
  </details>
  {{end}}

  {{if .Discovery.ProductionReachable}}
  <details open>
    <summary>Hosts de producción alcanzables (mala señal)</summary>
    <ul>
      {{range .Discovery.ProductionReachable}}<li><code>{{.}}</code></li>{{end}}
    </ul>
  </details>
  {{end}}

  {{if .Discovery.Secrets}}
  <details open>
    <summary>Secretos detectados en repositorio ({{.SecretsCount}}, {{.HighSecrets}} de severidad alta)</summary>
    <table class="discovery-table">
      <tr><th>Archivo</th><th>Línea</th><th>Patrón</th><th>Severidad</th><th>Match (redactado)</th></tr>
      {{range .Discovery.Secrets}}
      <tr>
        <td><code>{{.File}}</code></td>
        <td>{{.Line}}</td>
        <td>{{.Pattern}}</td>
        <td><span class="badge {{if eq .Severity "alto"}}high{{else}}med{{end}}">{{.Severity}}</span></td>
        <td><code>{{.Match}}</code></td>
      </tr>
      {{end}}
    </table>
  </details>
  {{end}}
</section>

<div class="footer">
  Generado por Staging Shield · {{.GeneratedAt}} · Modelo de Evaluación de Seguridad para Entornos de Preproducción
</div>

</div>
</body>
</html>
